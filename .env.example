# Copy to .env and set DATABASE_URL to match your Postgres.
# Example for container with POSTGRES_USER=proxify, POSTGRES_PASSWORD=proxify_password, POSTGRES_DB=proxify_db:
DATABASE_URL=postgresql://proxify:proxify_password@localhost:5432/proxify_db

# Optional: base URL for the demo script (default: http://localhost:3000)
# PROXIFY_BASE_URL=http://localhost:3000
